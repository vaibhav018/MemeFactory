# Secrets - never commit these
.env
credentials/service_account.json
credentials/oauth_token.json
.telegram_session.session

# Generated content
output/memes/*
!output/memes/.gitkeep
output/logs/*
!output/logs/.gitkeep
data/queue.json
data/news_cache.json

# Modern Mastery pipeline
data/post_history.db
queue/pending/*.json
queue/approved/*.json
queue/posted/*.json
!queue/pending/.gitkeep
!queue/approved/.gitkeep
!queue/posted/.gitkeep
# Generated_Memes IS committed — Actions needs public raw URLs for Instagram
assets/Downloaded/
logs/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db
