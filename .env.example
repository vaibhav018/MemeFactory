# Copy this file to .env and fill in real values. Never commit the real .env file.

# newsdata.io free-tier API key: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdataio_key_here

# Path to Google service account JSON (recommended over OAuth for a headless/scheduled pipeline)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# Instagram Graph API (Instagram Login flow - graph.instagram.com, no Facebook Page needed)
# Get IG_USER_ID from: https://graph.instagram.com/v21.0/me?fields=id,username&access_token=...
IG_ACCESS_TOKEN=your_instagram_access_token_here
IG_USER_ID=your_instagram_numeric_user_id_here
